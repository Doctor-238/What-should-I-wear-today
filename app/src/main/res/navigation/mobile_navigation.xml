<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.yehyun.whatshouldiweartoday.ui.home.HomeFragment"
        android:label="@string/title_home"
        tools:layout="@layout/fragment_home" >

        <argument
            android:name="target_tab"
            app:argType="integer"
            android:defaultValue="0" />

        <action
            android:id="@+id/action_navigation_home_to_saveStyleFragment"
            app:destination="@id/saveStyleFragment"
            app:enterAnim="@anim/slide_up_in"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/slide_down_out" />
        <action
            android:id="@+id/action_navigation_home_to_editClothingFragment"
            app:destination="@id/editClothingFragment"
            app:enterAnim="@anim/enter_from_right"
            app:exitAnim="@anim/exit_to_left"
            app:popEnterAnim="@anim/pop_enter_from_left"
            app:popExitAnim="@anim/pop_exit_to_right" />
        <action
            android:id="@+id/action_navigation_home_to_settingsFragment"
            app:destination="@id/settingsFragment"
            app:enterAnim="@anim/slide_up_in"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/slide_down_out" />
    </fragment>

    <fragment
        android:id="@+id/navigation_style"
        android:name="com.yehyun.whatshouldiweartoday.ui.style.StyleFragment"
        android:label="@string/title_style"
        tools:layout="@layout/fragment_style" >
        <action
            android:id="@+id/action_navigation_style_to_editStyleFragment"
            app:destination="@id/editStyleFragment"
            app:enterAnim="@anim/enter_from_right"
            app:exitAnim="@anim/exit_to_left"
            app:popEnterAnim="@anim/pop_enter_from_left"
            app:popExitAnim="@anim/pop_exit_to_right" />
    </fragment>

    <fragment
        android:id="@+id/navigation_closet"
        android:name="com.yehyun.whatshouldiweartoday.ui.closet.ClosetFragment"
        android:label="@string/title_closet"
        tools:layout="@layout/fragment_closet" >
        <action
            android:id="@+id/action_navigation_closet_to_addClothingFragment"
            app:destination="@id/addClothingFragment"
            app:enterAnim="@anim/enter_from_right"
            app:exitAnim="@anim/exit_to_left"
            app:popEnterAnim="@anim/pop_enter_from_left"
            app:popExitAnim="@anim/pop_exit_to_right" />
        <action
            android:id="@+id/action_navigation_closet_to_editClothingFragment"
            app:destination="@id/editClothingFragment"
            app:enterAnim="@anim/enter_from_right"
            app:exitAnim="@anim/exit_to_left"
            app:popEnterAnim="@anim/pop_enter_from_left"
            app:popExitAnim="@anim/pop_exit_to_right" />
        <action
            android:id="@+id/action_navigation_closet_to_shoppingFragment"
            app:destination="@id/shoppingFragment"
            app:enterAnim="@anim/enter_from_right"
            app:exitAnim="@anim/exit_to_left"
            app:popEnterAnim="@anim/pop_enter_from_left"
            app:popExitAnim="@anim/pop_exit_to_right" />
    </fragment>

    <fragment
        android:id="@+id/editClothingFragment"
        android:name="com.yehyun.whatshouldiweartoday.ui.closet.EditClothingFragment"
        android:label="fragment_edit_clothing"
        tools:layout="@layout/fragment_edit_clothing" >
        <argument
            android:name="clothingItemId"
            app:argType="integer" />
        <argument
            android:name="fromStyleEdit"
            app:argType="boolean"
            android:defaultValue="false" />
    </fragment>

    <fragment
        android:id="@+id/addClothingFragment"
        android:name="com.yehyun.whatshouldiweartoday.ui.closet.AddClothingFragment"
        android:label="AddClothingFragment"
        tools:layout="@layout/fragment_add_clothing" />

    <fragment
        android:id="@+id/saveStyleFragment"
        android:name="com.yehyun.whatshouldiweartoday.ui.style.SaveStyleFragment"
        android:label="fragment_save_style"
        tools:layout="@layout/fragment_save_style" >
        <argument
            android:name="preselected_ids"
            app:argType="integer[]"
            app:nullable="true"
            android:defaultValue="@null" />
        <action
            android:id="@+id/action_saveStyleFragment_to_editClothingFragment"
            app:destination="@id/editClothingFragment"
            app:enterAnim="@anim/enter_from_right"
            app:exitAnim="@anim/exit_to_left"
            app:popEnterAnim="@anim/pop_enter_from_left"
            app:popExitAnim="@anim/pop_exit_to_right" />
    </fragment>

    <fragment
        android:id="@+id/editStyleFragment"
        android:name="com.yehyun.whatshouldiweartoday.ui.style.EditStyleFragment"
        android:label="fragment_edit_style"
        tools:layout="@layout/fragment_edit_style" >
        <argument
            android:name="styleId"
            app:argType="long" />
        <action
            android:id="@+id/action_editStyleFragment_to_editClothingFragment"
            app:destination="@id/editClothingFragment"
            app:enterAnim="@anim/enter_from_right"
            app:exitAnim="@anim/exit_to_left"
            app:popEnterAnim="@anim/pop_enter_from_left"
            app:popExitAnim="@anim/pop_exit_to_right" />
    </fragment>

    <fragment
        android:id="@+id/shoppingFragment"
        android:name="com.yehyun.whatshouldiweartoday.ui.closet.ShoppingFragment"
        android:label="ShoppingFragment"
        tools:layout="@layout/fragment_shopping" >
        <action
            android:id="@+id/action_shoppingFragment_to_shoppingWebViewFragment"
            app:destination="@id/shoppingWebViewFragment"
            app:enterAnim="@anim/enter_from_right"
            app:exitAnim="@anim/exit_to_left"
            app:popEnterAnim="@anim/pop_enter_from_left"
            app:popExitAnim="@anim/pop_exit_to_right" />
        <action
            android:id="@+id/action_shoppingFragment_to_mallMainFragment"
            app:destination="@id/mallMainFragment"
            app:enterAnim="@anim/enter_from_right"
            app:exitAnim="@anim/exit_to_left"
            app:popEnterAnim="@anim/pop_enter_from_left"
            app:popExitAnim="@anim/pop_exit_to_right" />
    </fragment>

    <fragment
        android:id="@+id/mallMainFragment"
        android:name="com.yehyun.whatshouldiweartoday.ui.mall.MallMainFragment"
        android:label="MallMainFragment"
        tools:layout="@layout/fragment_mall_main">
        <action
            android:id="@+id/action_mallMainFragment_to_mallItemDetailFragment"
            app:destination="@id/mallItemDetailFragment"
            app:enterAnim="@anim/enter_from_right"
            app:exitAnim="@anim/exit_to_left"
            app:popEnterAnim="@anim/pop_enter_from_left"
            app:popExitAnim="@anim/pop_exit_to_right"/>
        <action
            android:id="@+id/action_mallMainFragment_to_mallAdminManageFragment"
            app:destination="@id/mallAdminManageFragment"
            app:enterAnim="@anim/enter_from_right"
            app:exitAnim="@anim/exit_to_left"
            app:popEnterAnim="@anim/pop_enter_from_left"
            app:popExitAnim="@anim/pop_exit_to_right"/>
        <action
            android:id="@+id/action_mallMainFragment_to_mallRecommendationFragment"
            app:destination="@id/mallRecommendationFragment"
            app:enterAnim="@anim/slide_up_in"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/slide_down_out"/>
        <action
            android:id="@+id/action_mallMainFragment_to_cartFragment"
            app:destination="@id/cartFragment"
            app:enterAnim="@anim/enter_from_right"
            app:exitAnim="@anim/exit_to_left"
            app:popEnterAnim="@anim/pop_enter_from_left"
            app:popExitAnim="@anim/pop_exit_to_right"/>
    </fragment>

    <fragment
        android:id="@+id/mallItemDetailFragment"
        android:name="com.yehyun.whatshouldiweartoday.ui.mall.MallItemDetailFragment"
        android:label="MallItemDetailFragment"
        tools:layout="@layout/fragment_mall_item_detail">
        <argument
            android:name="mall_item_id"
            app:argType="integer"/>
        <action
            android:id="@+id/action_mallItemDetailFragment_to_mallAdminEditFragment"
            app:destination="@id/mallAdminEditFragment"
            app:enterAnim="@anim/enter_from_right"
            app:exitAnim="@anim/exit_to_left"
            app:popEnterAnim="@anim/pop_enter_from_left"
            app:popExitAnim="@anim/pop_exit_to_right"/>
    </fragment>

    <fragment
        android:id="@+id/mallAdminManageFragment"
        android:name="com.yehyun.whatshouldiweartoday.ui.mall.MallAdminManageFragment"
        android:label="MallAdminManageFragment"
        tools:layout="@layout/fragment_mall_admin_manage">
        <action
            android:id="@+id/action_mallAdminManageFragment_to_mallAddItemFragment"
            app:destination="@id/mallAddItemFragment"
            app:enterAnim="@anim/enter_from_right"
            app:exitAnim="@anim/exit_to_left"
            app:popEnterAnim="@anim/pop_enter_from_left"
            app:popExitAnim="@anim/pop_exit_to_right"/>
        <action
            android:id="@+id/action_mallAdminManageFragment_to_mallAdminEditFragment"
            app:destination="@id/mallAdminEditFragment"
            app:enterAnim="@anim/enter_from_right"
            app:exitAnim="@anim/exit_to_left"
            app:popEnterAnim="@anim/pop_enter_from_left"
            app:popExitAnim="@anim/pop_exit_to_right"/>
    </fragment>

    <fragment
        android:id="@+id/mallAddItemFragment"
        android:name="com.yehyun.whatshouldiweartoday.ui.mall.MallAddItemFragment"
        android:label="MallAddItemFragment"
        tools:layout="@layout/fragment_mall_add_item"/>

    <fragment
        android:id="@+id/mallAdminEditFragment"
        android:name="com.yehyun.whatshouldiweartoday.ui.mall.MallAdminEditFragment"
        android:label="MallAdminEditFragment"
        tools:layout="@layout/fragment_mall_admin_edit">
        <argument
            android:name="mall_item_id"
            app:argType="integer"/>
    </fragment>

    <fragment
        android:id="@+id/mallRecommendationFragment"
        android:name="com.yehyun.whatshouldiweartoday.ui.mall.MallRecommendationFragment"
        android:label="MallRecommendationFragment"
        tools:layout="@layout/fragment_mall_recommendation"/>

    <fragment
        android:id="@+id/cartFragment"
        android:name="com.yehyun.whatshouldiweartoday.ui.mall.CartFragment"
        android:label="CartFragment"
        tools:layout="@layout/fragment_cart"/>

    <fragment
        android:id="@+id/shoppingWebViewFragment"
        android:name="com.yehyun.whatshouldiweartoday.ui.closet.ShoppingWebViewFragment"
        android:label="ShoppingWebViewFragment"
        tools:layout="@layout/fragment_shopping_webview" >
        <argument
            android:name="platform_name"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.yehyun.whatshouldiweartoday.ui.settings.SettingsFragment"
        android:label="fragment_settings"
        tools:layout="@layout/fragment_settings" />

    <action
        android:id="@+id/action_global_saveStyleFragment"
        app:destination="@id/saveStyleFragment"
        app:enterAnim="@anim/slide_up_in"
        app:exitAnim="@anim/fade_out"
        app:popEnterAnim="@anim/fade_in"
        app:popExitAnim="@anim/slide_down_out" />

    <action
        android:id="@+id/action_global_settingsFragment"
        app:destination="@id/settingsFragment"
        app:enterAnim="@anim/slide_up_in"
        app:exitAnim="@anim/fade_out"
        app:popEnterAnim="@anim/fade_in"
        app:popExitAnim="@anim/slide_down_out" />

</navigation>
