<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer shadow for floating depth -->
    <item android:top="3dp" android:left="2dp" android:right="2dp" android:bottom="-1dp">
        <shape android:shape="rectangle">
            <solid android:color="#35493AA0"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <!-- Main purple-blue gradient body -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#8070F0"
                android:centerColor="#6B7AEE"
                android:endColor="#5588F2"
                android:type="linear"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#50FFFFFF"/>
        </shape>
    </item>
    <!-- Strong top highlight - convex glass shine -->
    <item android:bottom="18dp" android:left="2dp" android:right="2dp" android:top="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#50FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear"/>
            <corners
                android:topLeftRadius="13dp"
                android:topRightRadius="13dp"
                android:bottomLeftRadius="4dp"
                android:bottomRightRadius="4dp"/>
        </shape>
    </item>
    <!-- Bottom inner shadow for depth -->
    <item android:top="20dp" android:left="2dp" android:right="2dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#20000030"
                android:endColor="#00000000"
                android:type="linear"/>
            <corners
                android:topLeftRadius="4dp"
                android:topRightRadius="4dp"
                android:bottomLeftRadius="13dp"
                android:bottomRightRadius="13dp"/>
        </shape>
    </item>
</layer-list>
