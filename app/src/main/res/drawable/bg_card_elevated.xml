<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep ambient shadow -->
    <item android:top="5dp" android:left="3dp" android:right="3dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#142B8EE8"/>
            <corners android:radius="26dp"/>
        </shape>
    </item>
    <!-- Mid shadow -->
    <item android:top="2dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#0A2B8EE8"/>
            <corners android:radius="25dp"/>
        </shape>
    </item>
    <!-- Card surface with subtle warm-to-cool gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#FFFFFF"
                android:centerColor="#FEFEFF"
                android:endColor="#F6F8FF"
                android:type="linear"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
    <!-- Inner highlight glow at top -->
    <item android:bottom="24dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#18FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear"/>
            <corners
                android:topLeftRadius="24dp"
                android:topRightRadius="24dp"
                android:bottomLeftRadius="4dp"
                android:bottomRightRadius="4dp"/>
        </shape>
    </item>
</layer-list>
