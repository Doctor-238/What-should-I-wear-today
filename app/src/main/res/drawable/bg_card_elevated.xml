<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="3dp" android:left="2dp" android:right="2dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#182B8EE8"/>
            <corners android:radius="26dp"/>
        </shape>
    </item>
    <item android:top="1dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#0C2B8EE8"/>
            <corners android:radius="25dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#FFFFFF"
                android:endColor="#F6FAFF"
                android:type="linear"/>
            <corners android:radius="24dp"/>
            <stroke android:width="1dp" android:color="@color/card_border"/>
        </shape>
    </item>
</layer-list>
