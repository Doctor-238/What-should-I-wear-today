<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item android:top="3dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#0C183050"/>
            <corners android:radius="22dp"/>
        </shape>
    </item>
    <!-- Main background: warm peach → amber gradient for contrast against blue theme -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#FFF5EE"
                android:centerColor="#FFF0E6"
                android:endColor="#FFEBDC"
                android:type="linear"/>
            <corners android:radius="20dp"/>
            <stroke android:width="1dp" android:color="#F0D8C4"/>
        </shape>
    </item>
</layer-list>
