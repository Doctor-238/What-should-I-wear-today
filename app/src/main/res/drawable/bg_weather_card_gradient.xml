<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep shadow for strong elevation feel -->
    <item android:top="6dp" android:left="4dp" android:right="4dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#381868C0"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
    <!-- Mid shadow -->
    <item android:top="3dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#201868C0"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
    <!-- Main rich gradient: sky blue → deep blue → indigo-purple -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#50C0F8"
                android:centerColor="#2888E8"
                android:endColor="#5060D8"
                android:type="linear"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
    <!-- Glass highlight overlay at top for 3D depth -->
    <item android:bottom="50dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#30FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear"/>
            <corners
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp"
                android:bottomLeftRadius="6dp"
                android:bottomRightRadius="6dp"/>
        </shape>
    </item>
    <!-- Warm accent glow at bottom-right for color variety -->
    <item android:top="40dp" android:left="40dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#00000000"
                android:endColor="#18FFB74D"
                android:type="linear"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
</layer-list>
