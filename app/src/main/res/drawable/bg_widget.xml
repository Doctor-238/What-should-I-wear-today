<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="4dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#14183050"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>
    <item android:top="2dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#0C183050"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#F8FCFF"
                android:endColor="#EDF5FF"
                android:type="linear"/>
            <corners android:radius="28dp"/>
            <stroke android:width="1dp" android:color="#C4DCF4"/>
        </shape>
    </item>
</layer-list>
