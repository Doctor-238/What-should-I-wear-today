<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep outer shadow -->
    <item android:top="5dp" android:left="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#18183050"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>
    <!-- Mid shadow -->
    <item android:top="3dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#10183050"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>
    <!-- Main body - strong vertical gradient for convex feel -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#FFFFFF"
                android:centerColor="#F6FAFF"
                android:endColor="#E4ECF6"
                android:type="linear"/>
            <corners android:radius="28dp"/>
            <stroke android:width="1dp" android:color="#B8D0E8"/>
        </shape>
    </item>
    <!-- Top highlight shine for strong convex -->
    <item android:bottom="50dp" android:left="6dp" android:right="6dp" android:top="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#50FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear"/>
            <corners
                android:topLeftRadius="26dp"
                android:topRightRadius="26dp"
                android:bottomLeftRadius="8dp"
                android:bottomRightRadius="8dp"/>
        </shape>
    </item>
    <!-- Bottom inner darkening for depth -->
    <item android:top="60dp" android:left="6dp" android:right="6dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#15203050"
                android:endColor="#00000000"
                android:type="linear"/>
            <corners
                android:topLeftRadius="8dp"
                android:topRightRadius="8dp"
                android:bottomLeftRadius="26dp"
                android:bottomRightRadius="26dp"/>
        </shape>
    </item>
</layer-list>
