<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle shadow -->
    <item android:top="2dp" android:left="1dp" android:right="1dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#0A183050"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
    <!-- Main background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#FFFFFF"
                android:endColor="#F8FBFF"
                android:type="linear"/>
            <corners android:radius="16dp"/>
            <stroke android:width="1dp" android:color="#D0DFEE"/>
        </shape>
    </item>
</layer-list>
