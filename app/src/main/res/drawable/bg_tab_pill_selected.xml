<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow shadow -->
    <item android:top="2dp" android:left="1dp" android:right="1dp" android:bottom="-1dp">
        <shape android:shape="rectangle">
            <solid android:color="#407B6AE8"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <!-- Purple-blue gradient pill -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#7B6AE8"
                android:centerColor="#6B7AEE"
                android:endColor="#5B8AF0"
                android:type="linear"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <!-- Glass highlight -->
    <item android:bottom="12dp" android:left="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#30FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear"/>
            <corners
                android:topLeftRadius="18dp"
                android:topRightRadius="18dp"
                android:bottomLeftRadius="6dp"
                android:bottomRightRadius="6dp"/>
        </shape>
    </item>
</layer-list>
