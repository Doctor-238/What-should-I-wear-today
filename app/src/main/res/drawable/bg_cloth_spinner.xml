<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow for depth -->
    <item android:top="4dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#102B8EE8"/>
            <corners android:radius="26dp"/>
        </shape>
    </item>
    <!-- Main background with warm-cool gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#FFFFFF"
                android:endColor="#F8FAFF"
                android:type="linear"/>
            <corners android:radius="24dp"/>
            <stroke android:width="1.5dp" android:color="@color/card_border"/>
        </shape>
    </item>
</layer-list>
