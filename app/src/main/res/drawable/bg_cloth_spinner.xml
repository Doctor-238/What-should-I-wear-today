<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="3dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#12183050"/>
            <corners android:radius="26dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#FFFFFF"
                android:endColor="#F4F9FF"
                android:type="linear"/>
            <corners android:radius="24dp"/>
            <stroke android:width="1.5dp" android:color="@color/card_border"/>
        </shape>
    </item>
</layer-list>
