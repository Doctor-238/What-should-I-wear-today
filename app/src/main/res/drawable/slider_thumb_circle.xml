<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="0dp">
        <shape android:shape="oval">
            <solid android:color="#1C183050"/>
            <size android:width="26dp" android:height="26dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:startColor="#FFFFFF"
                android:endColor="#EEF5FF"
                android:type="linear"/>
            <stroke android:width="2.5dp" android:color="@color/primary"/>
            <size android:width="26dp" android:height="26dp"/>
        </shape>
    </item>
</layer-list>
