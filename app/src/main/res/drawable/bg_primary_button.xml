<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="4dp" android:left="3dp" android:right="3dp" android:bottom="-2dp">
        <shape android:shape="rectangle">
            <solid android:color="#281868C0"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>
    <item android:top="2dp" android:left="1dp" android:right="1dp" android:bottom="-1dp">
        <shape android:shape="rectangle">
            <solid android:color="#141060A8"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#5BBEF8"
                android:centerColor="#2B8EE8"
                android:endColor="#1668C4"
                android:type="linear"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
    <item android:bottom="14dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#18FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear"/>
            <corners
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp"
                android:bottomLeftRadius="2dp"
                android:bottomRightRadius="2dp"/>
        </shape>
    </item>
</layer-list>
