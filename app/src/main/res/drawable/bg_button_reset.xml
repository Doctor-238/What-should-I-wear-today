<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="2dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#30103040"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#44B4BF"
                android:centerColor="#38A6B2"
                android:endColor="#2C98A4"
                android:type="linear"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
    <item android:bottom="20dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#30FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear"/>
            <corners
                android:topLeftRadius="26dp"
                android:topRightRadius="26dp"
                android:bottomLeftRadius="6dp"
                android:bottomRightRadius="6dp"/>
        </shape>
    </item>
</layer-list>
