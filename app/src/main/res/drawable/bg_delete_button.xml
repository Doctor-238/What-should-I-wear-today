<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="true">
        <layer-list>
            <item android:top="3dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#28A01010"/>
                    <corners android:radius="26dp"/>
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="145"
                        android:startColor="#FF6B5A"
                        android:centerColor="#E83030"
                        android:endColor="#CC1818"
                        android:type="linear"/>
                    <corners android:radius="24dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/delete_button_red_inactive"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
</selector>
