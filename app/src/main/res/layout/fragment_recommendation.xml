<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:clipToPadding="false"
    android:clipChildren="false"
    android:scrollbars="none"
    tools:context=".ui.home.RecommendationFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:paddingHorizontal="0dp"
        android:paddingTop="8dp"
        android:paddingBottom="36dp">

        <!-- Weather summary card with rich gradient -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_weather_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp"
            tools:visibility="visible">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/weather_card_min_height"
                android:background="@drawable/bg_weather_card_gradient">

                <!-- Full-bleed animation layer behind all content -->
                <com.yehyun.whatshouldiweartoday.ui.home.WeatherAnimView
                    android:id="@+id/wav_weather"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/tv_weather_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="오늘의 날씨"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:alpha="0.95"
                    android:letterSpacing="0.02"
                    android:layout_marginStart="22dp"
                    android:layout_marginTop="20dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <ImageView
                    android:id="@+id/iv_send_icon"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/send"
                    android:alpha="0.80"
                    app:layout_constraintBottom_toBottomOf="@id/tv_weather_title"
                    app:layout_constraintStart_toEndOf="@id/tv_weather_title"
                    app:layout_constraintTop_toTopOf="@id/tv_weather_title"
                    app:tint="#FFFFFF"/>

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/gl_split"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.57"/>

                <LinearLayout
                    android:id="@+id/ll_temp_group"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginStart="22dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="22dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/gl_split"
                    app:layout_constraintTop_toBottomOf="@id/tv_weather_title"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/iv_max_temp_icon"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/high_temperature"/>

                        <TextView
                            android:id="@+id/tv_max_temp_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="최고기온"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:alpha="0.85"
                            android:layout_marginTop="2dp"/>

                        <TextView
                            android:id="@+id/tv_max_temp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/temp_high_red"
                            android:textSize="34sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:layout_marginTop="1dp"
                            tools:text="17.4°"/>

                        <TextView
                            android:id="@+id/tv_max_feels_like"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:alpha="0.75"
                            android:layout_marginTop="1dp"
                            tools:text="체감 15.9°"/>
                    </LinearLayout>

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/iv_min_temp_icon"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/temperature"/>

                        <TextView
                            android:id="@+id/tv_min_temp_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="최저기온"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:alpha="0.85"
                            android:layout_marginTop="2dp"/>

                        <TextView
                            android:id="@+id/tv_min_temp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/temp_min_text"
                            android:textSize="34sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:layout_marginTop="1dp"
                            tools:text="1.3°"/>

                        <TextView
                            android:id="@+id/tv_min_feels_like"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:alpha="0.75"
                            android:layout_marginTop="1dp"
                            tools:text="체감 0.5°"/>
                    </LinearLayout>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Best combination card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_best_combination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:strokeWidth="0dp"
            android:visibility="gone"
            tools:visibility="visible">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:padding="18dp">

                <ImageView
                    android:id="@+id/iv_best_combination_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/sun"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_best_combination_title"
                    app:layout_constraintBottom_toBottomOf="@id/tv_best_combination_title"/>

                <TextView
                    android:id="@+id/tv_best_combination_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="최적의 코디"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/iv_best_combination_icon"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView
                    android:id="@+id/tv_best_combination_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="AI가 추천하는 오늘의 조합"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="@id/tv_best_combination_title"
                    app:layout_constraintTop_toBottomOf="@id/tv_best_combination_title"/>

                <Button
                    android:id="@+id/btn_save_combination"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="이 코디 저장"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:icon="@drawable/plus"
                    app:iconPadding="3dp"
                    app:iconTint="@color/primary"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_best_combination"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:paddingVertical="8dp"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_best_combination_subtitle"
                    tools:itemCount="3"
                    tools:listitem="@layout/item_recommendation_clothing_square"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- FIX #5: Empty state - no recommendation (improved with more visual appeal) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_no_recommendation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp"
            android:visibility="gone"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_empty_state_card"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="28dp"
                android:paddingVertical="48dp">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/offcloth"
                    android:alpha="0.6"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:text="추천할 옷이 부족해요"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:lineSpacingExtra="4sp"
                    android:text="날씨에 어울리는 옷이 부족합니다.\n'옷' 탭에서 옷을 더 등록해주세요!"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Hidden original text for backward compat -->
        <TextView
            android:id="@+id/tv_no_recommendation"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"/>

        <!-- Section: Tops -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="4dp"
                android:layout_height="22dp"
                android:background="@drawable/bg_section_accent"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/tv_tops_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="추천 상의"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:background="@drawable/bg_rank_gradient">

            <TextView
                android:id="@+id/tv_no_tops"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:text="옷장에 날씨에 맞는 상의가 없습니다!"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_tops"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:paddingHorizontal="4dp"
                android:paddingVertical="8dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="3"
                tools:listitem="@layout/item_recommendation_clothing_square"/>

        </FrameLayout>

        <!-- Section: Bottoms -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="4dp"
                android:layout_height="22dp"
                android:background="@drawable/bg_section_accent"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/tv_bottoms_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="추천 하의"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:background="@drawable/bg_rank_gradient">

            <TextView
                android:id="@+id/tv_no_bottoms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:text="옷장에 날씨에 맞는 하의가 없습니다!"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_bottoms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:paddingHorizontal="4dp"
                android:paddingVertical="8dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="5"
                tools:listitem="@layout/item_recommendation_clothing_square"/>

        </FrameLayout>

        <!-- Section: Outers -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="4dp"
                android:layout_height="22dp"
                android:background="@drawable/bg_section_accent"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/tv_outers_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="추천 아우터"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:background="@drawable/bg_rank_gradient">

            <TextView
                android:id="@+id/tv_no_outers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:text="옷장에 날씨에 맞는 아우터가 없습니다!"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_outers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:paddingHorizontal="4dp"
                android:paddingVertical="8dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="5"
                tools:listitem="@layout/item_recommendation_clothing_square"/>

        </FrameLayout>

        <!-- Info cards -->
        <LinearLayout
            android:id="@+id/ll_info_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            android:visibility="gone"
            tools:visibility="visible">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_temp_difference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_info_card"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_packable_bag"/>

                    <TextView
                        android:id="@+id/tv_info_temp_difference"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        tools:text="오늘은 일교차가 큰 날이에요!\n아우터를 따로 챙겨가는 것을 추천드립니다."/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_rain_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_info_card"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/umbrella"/>

                    <TextView
                        android:id="@+id/tv_info_rain"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        tools:text="비가 올 예정이니 우산을 꼭 챙겨주세요!"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
