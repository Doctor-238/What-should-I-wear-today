<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    tools:context=".ui.style.EditStyleFragment">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_edit_style"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_header_unified"
        android:elevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:menu="@menu/edit_style_menu"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:titleCentered="true"
        app:titleTextColor="@color/text_primary"
        app:titleTextAppearance="@style/TextAppearance.App.ToolbarTitle"/>

    <View
        android:id="@+id/toolbar_divider"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:background="@drawable/bg_header_to_content_fade"
        app:layout_constraintTop_toBottomOf="@id/toolbar_edit_style"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:clipChildren="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar_divider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipToPadding="false"
            android:paddingBottom="16dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout_edit_style_name"
                style="@style/Widget.App.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@color/text_input_box_stroke_color"
                app:counterEnabled="true"
                app:counterMaxLength="20"
                app:hintTextColor="@color/primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editText_edit_style_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="스타일 이름을 입력하세요 (최대 20자)"
                    android:inputType="text"
                    android:maxLength="20"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tv_season_label_edit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:text="계절 선택"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_season_edit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="10dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="6dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_spring_edit"
                    style="@style/Widget.App.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="봄"
                    android:textColor="@color/chip_textcolor_selector"
                    app:chipBackgroundColor="@color/chip_backgroundcolor_selector"
                    app:chipStrokeColor="@color/fab_color_style_tab"
                    app:chipStrokeWidth="1.5dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_summer_edit"
                    style="@style/Widget.App.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="여름"
                    android:textColor="@color/chip_textcolor_selector"
                    app:chipBackgroundColor="@color/chip_backgroundcolor_selector"
                    app:chipStrokeColor="@color/fab_color_style_tab"
                    app:chipStrokeWidth="1.5dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_fall_edit"
                    style="@style/Widget.App.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="가을"
                    android:textColor="@color/chip_textcolor_selector"
                    app:chipBackgroundColor="@color/chip_backgroundcolor_selector"
                    app:chipStrokeColor="@color/fab_color_style_tab"
                    app:chipStrokeWidth="1.5dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_winter_edit"
                    style="@style/Widget.App.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="겨울"
                    android:textColor="@color/chip_textcolor_selector"
                    app:chipBackgroundColor="@color/chip_backgroundcolor_selector"
                    app:chipStrokeColor="@color/fab_color_style_tab"
                    app:chipStrokeWidth="1.5dp"/>
            </com.google.android.material.chip.ChipGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:background="@color/divider_color"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:text="용도 선택"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_edit_style_purpose_chips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:orientation="horizontal"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_selected_items_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="현재 스타일 (0/10)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_selected_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:minHeight="110dp"
                        android:paddingBottom="4dp"
                        android:clipToPadding="false"
                        android:clipChildren="false"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                        app:spanCount="3"
                        tools:itemCount="3"
                        tools:listitem="@layout/item_clothing_selectable"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_header_to_content_fade"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:text="옷장에서 아이템 추가/제거"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout_edit_style_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_tab_gradient_purple"
                android:elevation="3dp"
                android:paddingHorizontal="4dp"
                app:tabBackground="@android:color/transparent"
                app:tabIndicator="@drawable/tab_indicator_custom"
                app:tabIndicatorAnimationMode="linear"
                app:tabIndicatorColor="@color/white"
                app:tabIndicatorFullWidth="false"
                app:tabIndicatorGravity="bottom"
                app:tabMode="scrollable"
                app:tabSelectedTextColor="@color/white"
                app:tabTextColor="#C0FFFFFF"
                app:tabTextAppearance="@style/TextAppearance.App.TabText"
                app:tabRippleColor="@android:color/transparent"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@drawable/bg_header_to_content_fade"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_all_items_for_edit"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginHorizontal="8dp"
                android:paddingHorizontal="4dp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="true"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="4"
                tools:listitem="@layout/item_clothing_selectable"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:background="@color/divider_color"/>

            <Button
                android:id="@+id/button_delete_style"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="20dp"
                android:text="삭제하기"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="15sp"
                android:background="@drawable/bg_button_danger"
                android:elevation="6dp"
                android:stateListAnimator="@null"
                app:backgroundTint="@null"/>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
