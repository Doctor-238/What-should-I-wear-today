<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    tools:context=".ui.style.SaveStyleFragment">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_save_style"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_header_unified"
        android:elevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="나만의 스타일 만들기"
        app:titleCentered="true"
        app:titleTextColor="@color/text_primary"
        app:titleTextAppearance="@style/TextAppearance.App.ToolbarTitle"/>

    <View
        android:id="@+id/toolbar_divider"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:background="@drawable/bg_header_to_content_fade"
        app:layout_constraintTop_toBottomOf="@id/toolbar_save_style"/>

    <ScrollView
        android:id="@+id/scroll_view_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar_divider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:paddingBottom="16dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout_style_name"
                style="@style/Widget.App.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@color/text_input_box_stroke_color"
                app:counterEnabled="true"
                app:counterMaxLength="20"
                app:hintTextColor="@color/primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editText_style_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="스타일 이름을 입력하세요 (최대 20자)"
                    android:inputType="text"
                    android:maxLength="20"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tv_season_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:text="계절 선택"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_season_save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="10dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="6dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_spring"
                    style="@style/Widget.App.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="봄"
                    android:textColor="@color/chip_textcolor_selector"
                    app:chipBackgroundColor="@color/chip_backgroundcolor_selector"
                    app:chipStrokeColor="@color/fab_color_style_tab"
                    app:chipStrokeWidth="1.5dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_summer"
                    style="@style/Widget.App.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="여름"
                    android:textColor="@color/chip_textcolor_selector"
                    app:chipBackgroundColor="@color/chip_backgroundcolor_selector"
                    app:chipStrokeColor="@color/fab_color_style_tab"
                    app:chipStrokeWidth="1.5dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_fall"
                    style="@style/Widget.App.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="가을"
                    android:textColor="@color/chip_textcolor_selector"
                    app:chipBackgroundColor="@color/chip_backgroundcolor_selector"
                    app:chipStrokeColor="@color/fab_color_style_tab"
                    app:chipStrokeWidth="1.5dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_winter"
                    style="@style/Widget.App.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="겨울"
                    android:textColor="@color/chip_textcolor_selector"
                    app:chipBackgroundColor="@color/chip_backgroundcolor_selector"
                    app:chipStrokeColor="@color/fab_color_style_tab"
                    app:chipStrokeWidth="1.5dp"/>

            </com.google.android.material.chip.ChipGroup>

            <TextView
                android:id="@+id/tv_selection_guide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:text="스타일에 포함할 옷을 선택하세요 (최대 10개)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout_save_style_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_tab_gradient_purple"
                android:elevation="3dp"
                android:paddingHorizontal="4dp"
                app:tabBackground="@android:color/transparent"
                app:tabGravity="fill"
                app:tabIndicator="@drawable/tab_indicator_custom"
                app:tabIndicatorAnimationMode="linear"
                app:tabIndicatorColor="@color/white"
                app:tabIndicatorFullWidth="false"
                app:tabIndicatorGravity="bottom"
                app:tabMode="scrollable"
                app:tabSelectedTextColor="@color/white"
                app:tabTextColor="#C0FFFFFF"
                app:tabTextAppearance="@style/TextAppearance.App.TabText"
                app:tabRippleColor="@android:color/transparent"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@drawable/bg_header_to_content_fade"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_clothing_selection"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:nestedScrollingEnabled="true"
                android:layout_marginHorizontal="8dp"
                android:paddingHorizontal="4dp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"
                android:clipToPadding="false"
                android:clipChildren="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="4"
                tools:listitem="@layout/item_clothing_selectable"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:background="@color/divider_color"/>

            <Button
                android:id="@+id/button_save_style_final"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="20dp"
                android:enabled="false"
                android:text="저장하기"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_primary_button"
                android:elevation="6dp"/>

        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"/>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
