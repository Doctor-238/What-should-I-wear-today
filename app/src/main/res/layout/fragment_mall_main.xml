<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mall_bg">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_mall_header"
        android:elevation="4dp"
        android:paddingBottom="14dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp">

            <ImageView
                android:id="@+id/iv_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="#FFFFFF"
                tools:ignore="ContentDescription"/>

            <ImageView
                android:id="@+id/iv_mall_logo"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_mall_logo"
                android:layout_marginStart="2dp"
                tools:ignore="ContentDescription"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="오늘 뭐 살래?"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginStart="8dp"/>

            <!-- Cart button with badge -->
            <FrameLayout
                android:id="@+id/btn_cart"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_cart"
                    tools:ignore="ContentDescription"/>

                <TextView
                    android:id="@+id/tv_cart_badge"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/bg_cart_badge"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone"/>
            </FrameLayout>

            <ImageView
                android:id="@+id/btn_admin"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:src="@drawable/ic_settings"
                android:tint="#FFFFFF60"
                android:layout_marginEnd="4dp"
                tools:ignore="ContentDescription"/>
        </LinearLayout>

        <!-- Search bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_mall_search_bar"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                android:tint="#FFFFFFCC"
                tools:ignore="ContentDescription"/>

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="브랜드, 상품명, 태그 검색"
                android:textColorHint="#FFFFFF80"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:paddingStart="10dp"
                android:paddingEnd="4dp"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:singleLine="true"/>

            <ImageView
                android:id="@+id/iv_search_clear"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_close"
                android:tint="#FFFFFFAA"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:visibility="gone"
                tools:ignore="ContentDescription"/>
        </LinearLayout>

        <!-- Category tabs -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginTop="6dp"
            android:paddingHorizontal="12dp">

            <LinearLayout
                android:id="@+id/tab_container"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_mall_tab_container"
                android:paddingHorizontal="4dp"
                android:paddingVertical="4dp">

                <TextView
                    android:id="@+id/tab_all"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="전체"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_mall_tab_selected"/>

                <TextView
                    android:id="@+id/tab_top"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:text="상의"
                    android:textSize="13sp"
                    android:textColor="#FFFFFFCC"
                    android:layout_marginStart="4dp"/>

                <TextView
                    android:id="@+id/tab_bottom"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:text="하의"
                    android:textSize="13sp"
                    android:textColor="#FFFFFFCC"
                    android:layout_marginStart="4dp"/>

                <TextView
                    android:id="@+id/tab_outer"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:text="아우터"
                    android:textSize="13sp"
                    android:textColor="#FFFFFFCC"
                    android:layout_marginStart="4dp"/>

                <TextView
                    android:id="@+id/tab_shoes"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:text="신발"
                    android:textSize="13sp"
                    android:textColor="#FFFFFFCC"
                    android:layout_marginStart="4dp"/>

                <TextView
                    android:id="@+id/tab_acc"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:text="기타"
                    android:textSize="13sp"
                    android:textColor="#FFFFFFCC"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Admin banner -->
    <LinearLayout
        android:id="@+id/layout_admin_banner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#E8FF6B6B"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="관리자 모드 활성화"
            android:textSize="13sp"
            android:textColor="#CC0000"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btn_goto_admin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="관리 화면 →"
            android:textSize="13sp"
            android:textColor="#CC0000"
            android:textStyle="bold"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"/>

        <TextView
            android:id="@+id/btn_admin_logout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="로그아웃"
            android:textSize="12sp"
            android:textColor="#888888"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- Result count bar -->
    <LinearLayout
        android:id="@+id/layout_result_bar"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/layout_admin_banner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_item_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="@color/text_tertiary"
            tools:text="상품 12개"/>
    </LinearLayout>

    <!-- Product grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_products"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="4dp"
        android:paddingBottom="88dp"
        app:layout_constraintTop_toBottomOf="@id/layout_result_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layout_empty"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layout_result_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_mall_logo"
            android:alpha="0.25"
            tools:ignore="ContentDescription"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="상품이 없어요"
            android:textSize="16sp"
            android:textColor="@color/text_tertiary"
            android:layout_marginTop="12dp"/>

        <TextView
            android:id="@+id/tv_empty_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="다른 카테고리를 확인해보세요"
            android:textSize="13sp"
            android:textColor="@color/text_tertiary"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- AI Recommendation FAB -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_recommend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:text="AI 맞춤 추천"
        android:textColor="#FFFFFF"
        app:icon="@drawable/ic_mall_logo"
        app:iconTint="#FFFFFF"
        android:backgroundTint="#FF6B6B"
        app:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
