<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_mall_header"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="#FFFFFF"
        app:title="상품 관리 (관리자)"
        app:titleCentered="true"
        app:titleTextColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Category tabs -->
    <HorizontalScrollView
        android:id="@+id/scroll_tabs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:background="@color/surface"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/tab_container"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_tab_container"
            android:paddingHorizontal="4dp"
            android:paddingVertical="3dp">

            <TextView android:id="@+id/tab_all" android:layout_width="wrap_content" android:layout_height="28dp"
                android:gravity="center" android:paddingHorizontal="16dp" android:text="전체"
                android:textSize="13sp" android:textStyle="bold" android:textColor="#FFFFFF"
                android:background="@drawable/bg_mall_tab_selected"/>
            <TextView android:id="@+id/tab_top" android:layout_width="wrap_content" android:layout_height="28dp"
                android:gravity="center" android:paddingHorizontal="14dp" android:text="상의"
                android:textSize="13sp" android:textColor="@color/text_secondary" android:layout_marginStart="4dp"/>
            <TextView android:id="@+id/tab_bottom" android:layout_width="wrap_content" android:layout_height="28dp"
                android:gravity="center" android:paddingHorizontal="14dp" android:text="하의"
                android:textSize="13sp" android:textColor="@color/text_secondary" android:layout_marginStart="4dp"/>
            <TextView android:id="@+id/tab_outer" android:layout_width="wrap_content" android:layout_height="28dp"
                android:gravity="center" android:paddingHorizontal="14dp" android:text="아우터"
                android:textSize="13sp" android:textColor="@color/text_secondary" android:layout_marginStart="4dp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Delete mode bar -->
    <LinearLayout
        android:id="@+id/layout_delete_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFEBE8"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/scroll_tabs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_delete_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0개 선택됨"
            android:textSize="13sp"
            android:textColor="#CC0000"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_delete_selected"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="삭제"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E03030"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_cancel_delete"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="취소"
            android:textColor="@color/text_secondary"
            android:backgroundTint="@color/surface"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_products"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/layout_delete_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:text="상품 추가"
        android:textColor="#FFFFFF"
        app:icon="@drawable/ic_plus"
        app:iconTint="#FFFFFF"
        android:backgroundTint="#FF6B6B"
        app:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
