<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    tools:context=".ui.closet.EditClothingFragment">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_edit"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_header_unified"
        android:elevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="옷 수정"
        app:titleCentered="true"
        app:titleTextColor="@color/text_primary"
        app:titleTextAppearance="@style/TextAppearance.App.ToolbarTitle"
        app:menu="@menu/edit_clothing_menu"/>

    <View
        android:id="@+id/toolbar_divider"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:background="@drawable/bg_header_to_content_fade"
        app:layout_constraintTop_toBottomOf="@id/toolbar_edit"/>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:clipChildren="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar_divider">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="20dp"
            android:paddingBottom="36dp">

            <FrameLayout
                android:id="@+id/frameLayout_edit_preview"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginHorizontal="20dp"
                android:background="@drawable/bg_cloth_spinner"
                android:padding="12dp"
                android:elevation="6dp"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/imageView_edit_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    tools:src="@tools:sample/backgrounds/scenic"/>

                <ImageView
                    android:id="@+id/icon_special_edit"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="10dp"
                    android:visibility="gone"
                    tools:src="@tools:sample/sun"
                    tools:visibility="visible"/>

            </FrameLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_ai_info_edit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/frameLayout_edit_preview">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="4dp">

                    <!-- FIX #4: Temperature area — hint only shows for non-temp categories, replacing temp controls -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="14dp">

                        <TextView
                            android:id="@+id/tv_edit_temp_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="적정 온도"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>

                        <!-- Hint: only visible when category is NOT 상의/하의/아우터 -->
                        <TextView
                            android:id="@+id/tv_edit_temp_hint"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="상의, 하의, 아우터에만 표시됩니다."
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp"
                            android:gravity="end"
                            android:layout_marginStart="8dp"
                            android:visibility="gone"
                            app:layout_constraintBottom_toBottomOf="@id/tv_edit_temp_label"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/tv_edit_temp_label"
                            app:layout_constraintTop_toTopOf="@id/tv_edit_temp_label"/>

                        <!-- Temperature controls: only visible when category IS 상의/하의/아우터 -->
                        <ImageButton
                            android:id="@+id/button_edit_temp_decrease"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_button_minus"
                            android:contentDescription="온도 내리기"
                            android:src="@drawable/ic_minus"
                            android:elevation="3dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/textView_edit_temperature"
                            app:layout_constraintTop_toTopOf="parent"/>

                        <TextView
                            android:id="@+id/textView_edit_temperature"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/button_edit_temp_increase"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:text="-7.5°C ~ -2.5°C"/>

                        <ImageButton
                            android:id="@+id/button_edit_temp_increase"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_button_plus"
                            android:contentDescription="온도 올리기"
                            android:src="@drawable/ic_plus"
                            android:elevation="3dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:text="색상"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <View
                            android:id="@+id/view_color_swatch_edit"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:elevation="2dp"
                            tools:background="#000000"/>
                    </RelativeLayout>

                    <View
                        android:id="@+id/divider_edit_fit_level"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"/>

                    <RelativeLayout
                        android:id="@+id/layout_edit_fit_level"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="체형"
                            android:textStyle="bold"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tv_edit_fit_level"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="적합"/>
                    </RelativeLayout>

                    <View
                        android:id="@+id/divider_edit_purpose"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"
                        android:visibility="gone"/>

                    <RelativeLayout
                        android:id="@+id/layout_edit_purpose"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="14dp"
                        android:visibility="gone">
                        <TextView
                            android:id="@+id/tv_purpose_label_edit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="용도"
                            android:textStyle="bold"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tv_edit_purpose"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/tv_purpose_label_edit"
                            android:layout_marginStart="16dp"
                            android:gravity="end"
                            android:textColor="@color/primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="일상용, 활동용"/>
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"/>

                    <RelativeLayout
                        android:id="@+id/layout_background_removal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:text="배경 제거"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_edit_remove_background"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"/>
                    </RelativeLayout>

                    <!-- Purchase source section -->
                    <View
                        android:id="@+id/divider_purchase_source"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"
                        android:visibility="gone"/>

                    <RelativeLayout
                        android:id="@+id/layout_purchase_source"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:text="구매처"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <LinearLayout
                            android:id="@+id/ll_purchase_source"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/iv_purchase_source_icon"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:scaleType="fitCenter"
                                android:layout_marginEnd="6dp"
                                android:visibility="gone"
                                tools:ignore="ContentDescription"/>

                            <TextView
                                android:id="@+id/tv_purchase_source"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textColor="@color/text_secondary"
                                tools:text="쿠팡에서 구매"/>
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout_edit_name"
                style="@style/Widget.App.TextInputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@color/text_input_box_stroke_color"
                app:counterEnabled="true"
                app:counterMaxLength="20"
                app:hintTextColor="@color/primary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_ai_info_edit">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editText_edit_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="옷 이름"
                    android:inputType="text"
                    android:maxLength="20"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/textView_edit_category_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:text="종류"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textInputLayout_edit_name"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroup_edit_category"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="10dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="6dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textView_edit_category_label"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_edit_top"
                    style="@style/Widget.App.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="상의"
                    android:textColor="@color/chip_textcolor_selector"
                    app:chipBackgroundColor="@color/chip_backgroundcolor_selector"
                    app:chipStrokeColor="@color/fab_color_style_tab"
                    app:chipStrokeWidth="1.5dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_edit_bottom"
                    style="@style/Widget.App.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="하의"
                    android:textColor="@color/chip_textcolor_selector"
                    app:chipBackgroundColor="@color/chip_backgroundcolor_selector"
                    app:chipStrokeColor="@color/fab_color_style_tab"
                    app:chipStrokeWidth="1.5dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_edit_outer"
                    style="@style/Widget.App.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="아우터"
                    android:textColor="@color/chip_textcolor_selector"
                    app:chipBackgroundColor="@color/chip_backgroundcolor_selector"
                    app:chipStrokeColor="@color/fab_color_style_tab"
                    app:chipStrokeWidth="1.5dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_edit_shoe"
                    style="@style/Widget.App.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="신발"
                    android:textColor="@color/chip_textcolor_selector"
                    app:chipBackgroundColor="@color/chip_backgroundcolor_selector"
                    app:chipStrokeColor="@color/fab_color_style_tab"
                    app:chipStrokeWidth="1.5dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_edit_bag"
                    style="@style/Widget.App.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="가방"
                    android:textColor="@color/chip_textcolor_selector"
                    app:chipBackgroundColor="@color/chip_backgroundcolor_selector"
                    app:chipStrokeColor="@color/fab_color_style_tab"
                    app:chipStrokeWidth="1.5dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_edit_hat"
                    style="@style/Widget.App.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="모자"
                    android:textColor="@color/chip_textcolor_selector"
                    app:chipBackgroundColor="@color/chip_backgroundcolor_selector"
                    app:chipStrokeColor="@color/fab_color_style_tab"
                    app:chipStrokeWidth="1.5dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_edit_other"
                    style="@style/Widget.App.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="기타"
                    android:textColor="@color/chip_textcolor_selector"
                    app:chipBackgroundColor="@color/chip_backgroundcolor_selector"
                    app:chipStrokeColor="@color/fab_color_style_tab"
                    app:chipStrokeWidth="1.5dp"/>

            </com.google.android.material.chip.ChipGroup>

            <Button
                android:id="@+id/button_delete"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                android:layout_marginHorizontal="20dp"
                android:text="삭제하기"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="15sp"
                android:background="@drawable/bg_button_danger"
                android:elevation="6dp"
                android:stateListAnimator="@null"
                app:backgroundTint="@null"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/chipGroup_edit_category"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
