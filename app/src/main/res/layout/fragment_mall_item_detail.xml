<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mall_bg">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_mall_header"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="#FFFFFF"
        app:title="상품 상세"
        app:titleCentered="true"
        app:titleTextColor="#FFFFFF"
        android:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Bottom buy bar (fixed) -->
    <LinearLayout
        android:id="@+id/layout_buy_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp"
        android:background="@color/surface"
        android:elevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Wishlist button -->
        <FrameLayout
            android:id="@+id/btn_wishlist"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_wishlist_btn"
            android:layout_marginEnd="8dp">

            <ImageView
                android:id="@+id/iv_wishlist_btn"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_heart_outline"
                android:scaleType="fitCenter"/>
        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_cart"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="장바구니"
            android:textColor="@color/mall_accent"
            android:backgroundTint="@color/mall_accent_light"
            app:cornerRadius="10dp"
            android:layout_marginEnd="8dp"
            app:strokeColor="@color/mall_accent"
            app:strokeWidth="1dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_buy_now"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1.5"
            android:text="바로 구매"
            android:textColor="@color/white"
            android:backgroundTint="@color/mall_header_start"
            app:cornerRadius="10dp"/>
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/layout_buy_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- === IMAGE SECTION === -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/iv_product_image"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        app:layout_constraintDimensionRatio="4:5"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:scaleType="centerCrop"
                        android:background="#F0F0F0"/>

                    <View
                        android:id="@+id/view_color_bg"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:visibility="gone"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Discount/New badge on image -->
                <TextView
                    android:id="@+id/tv_detail_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/bg_discount_badge"
                    android:visibility="gone"/>
            </FrameLayout>

            <!-- === MAIN INFO SECTION (white card) === -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp">

                <!-- Brand + Rating row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_brand"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/mall_accent"/>

                    <!-- Rating summary -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="13dp"
                            android:layout_height="13dp"
                            android:src="@drawable/ic_star_filled"
                            android:scaleType="fitCenter"/>

                        <TextView
                            android:id="@+id/tv_rating_header"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="@color/mall_star_gold"
                            android:textStyle="bold"
                            android:layout_marginStart="3dp"
                            tools:text="4.7"/>

                        <TextView
                            android:id="@+id/tv_review_count_header"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/text_tertiary"
                            android:layout_marginStart="3dp"
                            tools:text="(128)"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Product name -->
                <TextView
                    android:id="@+id/tv_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="3dp"/>

                <!-- Price row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="14dp">

                    <TextView
                        android:id="@+id/tv_discount_rate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/mall_accent"
                        android:layout_marginEnd="6dp"
                        android:visibility="gone"
                        tools:text="30%"/>

                    <TextView
                        android:id="@+id/tv_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tv_original_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/mall_original_price"
                        android:layout_marginStart="10dp"
                        android:visibility="gone"
                        tools:text="99,000원"/>
                </LinearLayout>

                <!-- Delivery info row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="무료배송"
                        android:textSize="11sp"
                        android:textColor="@color/mall_free_ship_text"
                        android:textStyle="bold"
                        android:paddingHorizontal="7dp"
                        android:paddingVertical="3dp"
                        android:background="@drawable/bg_free_ship_chip"/>

                    <TextView
                        android:id="@+id/tv_delivery_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/text_tertiary"
                        android:layout_marginStart="8dp"
                        tools:text="오늘 주문시 내일 도착 예정"/>
                </LinearLayout>

                <!-- Tags -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginTop="14dp">

                    <LinearLayout
                        android:id="@+id/ll_tags"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"/>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- Thick divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/mall_bg"/>

            <!-- === SIZE SECTION === -->
            <LinearLayout
                android:id="@+id/layout_size_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface"
                android:paddingHorizontal="20dp"
                android:paddingVertical="20dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="사이즈 선택"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tv_size_guide"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="사이즈 가이드"
                        android:textSize="12sp"
                        android:textColor="@color/mall_accent"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="4dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_size_required"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="사이즈를 선택해주세요"
                    android:textSize="12sp"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginTop="2dp"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginTop="14dp">

                    <LinearLayout
                        android:id="@+id/ll_sizes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"/>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- Size section divider -->
            <View
                android:id="@+id/size_section_divider"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/mall_bg"
                android:visibility="gone"/>

            <!-- === PRODUCT INFO SECTION === -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface"
                android:paddingHorizontal="20dp"
                android:paddingVertical="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="상품 정보"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="14dp"/>

                <!-- Category row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="카테고리"
                        android:textSize="13sp"
                        android:textColor="@color/text_tertiary"/>

                    <TextView
                        android:id="@+id/tv_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- Season row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="시즌"
                        android:textSize="13sp"
                        android:textColor="@color/text_tertiary"/>

                    <TextView
                        android:id="@+id/tv_season"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- Material row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="소재"
                        android:textSize="13sp"
                        android:textColor="@color/text_tertiary"/>

                    <TextView
                        android:id="@+id/tv_material"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        tools:text="면 100%"/>
                </LinearLayout>

                <!-- Temp row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="적정 온도"
                        android:textSize="13sp"
                        android:textColor="@color/text_tertiary"/>

                    <TextView
                        android:id="@+id/tv_temp_range"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        tools:text="10°C ~ 20°C"/>
                </LinearLayout>

                <!-- Color row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="색상"
                        android:textSize="13sp"
                        android:textColor="@color/text_tertiary"/>

                    <View
                        android:id="@+id/view_color_chip"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tv_color_hex"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone"/>
                </LinearLayout>

                <!-- Body fit row -->
                <LinearLayout
                    android:id="@+id/layout_fit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="사이즈"
                        android:textSize="13sp"
                        android:textColor="@color/text_tertiary"/>

                    <TextView
                        android:id="@+id/tv_fit_info"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- Purpose row -->
                <LinearLayout
                    android:id="@+id/layout_purpose"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="용도"
                        android:textSize="13sp"
                        android:textColor="@color/text_tertiary"/>

                    <TextView
                        android:id="@+id/tv_purpose"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Description section (conditionally shown) -->
            <View
                android:id="@+id/divider_purpose"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/mall_bg"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/card_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface"
                android:paddingHorizontal="20dp"
                android:paddingVertical="20dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="상품 설명"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tv_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingExtra="6dp"/>
            </LinearLayout>

            <!-- Thick divider before reviews -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/mall_bg"/>

            <!-- === REVIEWS SECTION === -->
            <LinearLayout
                android:id="@+id/layout_reviews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp">

                <!-- Reviews header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="구매 후기"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tv_total_review_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/text_tertiary"
                        tools:text="128개"/>
                </LinearLayout>

                <!-- Rating overview -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <!-- Big average score -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="20dp">

                        <TextView
                            android:id="@+id/tv_avg_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="44sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            tools:text="4.7"/>

                        <LinearLayout
                            android:id="@+id/ll_avg_stars"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="/ 5.0"
                            android:textSize="11sp"
                            android:textColor="@color/text_tertiary"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>

                    <!-- Rating distribution bars -->
                    <LinearLayout
                        android:id="@+id/ll_rating_bars"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"/>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F0F0F0"
                    android:layout_marginBottom="4dp"/>

                <!-- Review cards container -->
                <LinearLayout
                    android:id="@+id/ll_reviews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <!-- More reviews button -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="후기 더보기 ›"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:background="?attr/selectableItemBackground"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Thick divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/mall_bg"/>

            <!-- === RETURN POLICY SECTION === -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface"
                android:paddingHorizontal="20dp"
                android:paddingVertical="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="교환/반품 안내"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="· 상품 수령 후 7일 이내 교환/반품 가능\n· 착용/세탁 후 교환/반품 불가\n· 제품 불량 시 100% 교환/환불 보장\n· 무료 반품 (1회 제공)"
                    android:textSize="12sp"
                    android:textColor="@color/text_tertiary"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <!-- Admin edit button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_admin_edit"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:text="관리자: 상품 수정"
                android:textColor="@color/white"
                android:backgroundTint="#AAAAAA"
                app:cornerRadius="8dp"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
